{
	"reload_style_on_change": true,
	"layer": "top",
	"position": "top",
	"spacing": 0,
	"height": 26,
	"modules-left": ["custom/kernel","custom/operator" ,"niri/workspaces", "network", "bluetooth"],
	"modules-center": ["clock"],
	"modules-right": [
		"tray",
		"pulseaudio",
		"cpu",
		"memory",
		"battery",
		"niri/language"

	],
	"niri/workspaces": {
		"on-click": "activate",
		"format": "{icon}",
		"format-icons": {
			"default": "🗺",
			"active": "💥"
		}
	},


	"memory": {
		"interval": 3,
		/*{percentage}%*/
		"format": " {icon}",
		"format-icons": [
			"░░░░░░░░░░",
			"█░░░░░░░░░",
			"██░░░░░░░░",
			"███░░░░░░░",
			"████░░░░░░",
			"█████░░░░░",
			"██████░░░░",
			"███████░░░",
			"████████░░",
			"█████████░",
			"██████████"
		] 
	},

	"cpu": {
		"interval": 3,
		"format": " {icon}",
		"format-icons": [
			"░░░░░░░░░░",
			"█░░░░░░░░░",
			"██░░░░░░░░",
			"███░░░░░░░",
			"████░░░░░░",
			"█████░░░░░",
			"██████░░░░",
			"███████░░░",
			"████████░░",
			"█████████░",
			"██████████"
		]
	},

	"clock": {
		"format": "󰥔 {:L%A %d %b %I:%M %p}",   // 12h with date
		"format-alt": "󰥔 {:L%A %d %b %H:%M}",  // 24h with date
		"tooltip": false
	},

	"network": {
		"format-wifi": "󰤨 {essid}",
		"format-ethernet": "󰀂 Wired{ip}",
		"format-disconnected": "󰤮 Offline",
		"tooltip-format-wifi": "{essid} ({signalStrength}%)\n⇣{bandwidthDownBytes} ⇡{bandwidthUpBytes}",
		"tooltip-format-ethernet": "Wired\n⇣{bandwidthDownBytes} ⇡{bandwidthUpBytes}",
		"interval": 3
	},
	"battery": {
		"format": "{icon}",
		"format-charging": "🗲 {icon}",
		"format-discharging": "{icon}",
		"format-plugged": "🗲 {icon}",
		
		"format-icons": {
			"default": [
				"▱▱▱▱▱", 
				"▰▱▱▱▱",
				"▰▰▱▱▱", 
				"▰▰▰▱▱", 
				"▰▰▰▰▱", 
				"▰▰▰▰▰"
			]
		},
		"interval": 5,
		"states": {
			"warning": 30,
			"critical": 10
		}
	},

	"bluetooth": {
		"format": "󰂲",
		"format-connected": "󰂱 {device_alias}",
		"format-disabled": "󰂲",
		"format-off": "󰂲",
		"tooltip-format": "{device_alias}",
		"on-click": "blueman-manager"
	},

	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-muted": " Muted",
		"format-icons": {
			"headphone": "",
			"default": ["", " ", " "]
		},
		"scroll-step": 5,
		"on-click": "",
		"on-click-right": ""
	},

	"tray": {
		"icon-size": 12,
		"spacing": 15
	},

	"custom/kernel": {
		"exec": "uname -r | cut -d'-' -f1",
		"interval": 3600,
		"format": " {}"
	},

	"custom/operator": {
		"format": "▄︻╦デ══───━"
	},

	"niri/language": {
		"format": "{}  ",
		"format-ar":"ع",
		"format-en":"EN" 
	}
}

